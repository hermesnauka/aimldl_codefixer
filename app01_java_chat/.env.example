# Copy to .env and fill in real values. Never commit .env itself.

# --- Postgres ---
POSTGRES_USER=codefixer
POSTGRES_PASSWORD=codefixer
POSTGRES_DB=codefixer
DATABASE_URL=postgres://codefixer:codefixer@postgres:5432/codefixer

# --- Gateway (Node.js) ---
GATEWAY_PORT=4000
JWT_SECRET=dev-only-secret-change-me-min-32-bytes-long
ORCHESTRATOR_URL=http://orchestrator:8000

# --- Orchestrator (Python/LangGraph) ---
ORCHESTRATOR_PORT=8000
WORKER_URL=http://worker:8100
INTEGRATION_BRIDGE_URL=http://integration-bridge:8080

# Primary LLM: Hermes 3 via OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=nousresearch/hermes-3-llama-3.1-405b

# Fallback LLM: OpenAI Codex/ChatGPT
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# US-04: failover after this many consecutive failures / this timeout
LLM_FAILOVER_MAX_ATTEMPTS=2
LLM_FAILOVER_TIMEOUT_SECONDS=3.0

# --- Worker (OpenCode sandbox) ---
WORKER_PORT=8100
WORKER_EXECUTION_TIMEOUT_SECONDS=10
# Docker socket the worker uses to launch isolated per-request containers —
# only meaningful when the worker itself runs outside a container with
# access to the host/sibling Docker daemon. See worker/README.md.
DOCKER_HOST=unix:///var/run/docker.sock

# --- Integration Bridge (Java/Spring Boot) ---
BRIDGE_PORT=8080

# --- Frontend ---
VITE_GATEWAY_URL=http://localhost:4000
